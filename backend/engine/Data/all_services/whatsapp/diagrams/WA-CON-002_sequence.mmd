sequenceDiagram
    participant User as Benutzer
    participant System as System
    participant Database as Datenbank

    User->>System: Kontakt hinzufügen wählen
    System->>User: Auswahl der Methoden anzeigen
    User->>System: Methode auswählen (z.B. manuell, Import)
    alt Manuelle Eingabe
        User->>System: Kontaktdaten eingeben
        System->>Database: Kontaktdaten speichern
        Database-->>System: Bestätigung
        System-->>User: Kontakt hinzugefügt
    else Import
        User->>System: Datei zum Importieren auswählen
        System->>Database: Daten aus Datei importieren
        Database-->>System: Bestätigung
        System-->>User: Kontakte hinzugefügt
    end