classDiagram
    class StickerPack {
        +String name
        +String region
        +List<Sticker> stickers
        +addSticker(Sticker sticker)
        +removeSticker(Sticker sticker)
    }

    class Sticker {
        +String id
        +String imageUrl
        +String description
        +boolean isAvailable
    }

    class User {
        +String userId
        +String username
        +List<StickerPack> ownedStickerPacks
        +addStickerPack(StickerPack stickerPack)
        +removeStickerPack(StickerPack stickerPack)
    }

    class Region {
        +String regionId
        +String regionName
        +List<StickerPack> availableStickerPacks
    }

    StickerPack "1" -- "*" Sticker : contains
