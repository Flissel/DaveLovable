classDiagram
    class Gruppenadministration {
        +createGroup()
        +deleteGroup()
        +addMember()
        +removeMember()
        +assignRole()
        +revokeRole()
        +listGroups()
        +getGroupDetails()
    }

    class Group {
        +groupId: String
        +groupName: String
        +members: List<Member>
        +roles: List<Role>
    }

    class Member {
        +memberId: String
        +memberName: String
        +email: String
    }

    class Role {
        +roleId: String
        +roleName: String
    }

    Gruppenadministration --> Group : manages
    Group --> Member : contains
    Group --> Role : defines